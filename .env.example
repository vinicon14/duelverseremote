# Token do bot Discord (obrigatório)
DISCORD_TOKEN=seu_token_aqui

# URL do servidor WebSocket do DuelVerse (opcional, padrão: ws://localhost:8080)
DUELVERSE_URL=ws://localhost:8080

# Nome do canal Discord para sincronização (opcional, padrão: global-chat)
DISCORD_CHANNEL=global-chat

# Google Ad Manager rewarded video ads (web)
# Use o caminho completo do bloco recompensado, por exemplo:
# VITE_GAM_REWARDED_AD_UNIT_PATH=/1234567/duelverse_rewarded_video
VITE_GAM_REWARDED_AD_UNIT_PATH=

# Discord Embedded App / Activity
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_publica
VITE_DISCORD_SUPABASE_MAPPING_PREFIX=
